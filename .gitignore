### Linux ###
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

### Application Specific ###
# H2 Database files
*.h2.db
*.trace.db

# Application logs
logs/
spring.log

# Configuration files with sensitive data
application-prod.properties
application-local.properties
application-dev.properties
!application.properties
!application.yml

# JWT Secret files (if stored separately)
jwt-secret.txt
secrets/

# Upload directories
uploads/
files/
temp/

# Test coverage reports
coverage/
.nyc_output/

# Environment variables
.env
.env.local
.env.*.local

# Backup files
*.backup
*.old

# Cache directories
.cache/

# npm (if frontend is included later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

### Custom TaskFlow ignores ###
# Generated documentation
docs/generated/

# Temporary files
*.tmp
temp-*

# Database migration backups
db-backup/

# Custom logs
taskflow.log
error.log

# IDE specific workspace files
workspace.xml
tasks.xml